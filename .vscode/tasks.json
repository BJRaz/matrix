{
    // See https://go.microsoft.com/fwlink/?LinkId=733558 
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "type": "npm",
            "script": "build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "label": "build",
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "type": "npm",
            "script": "test",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "label": "test",
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "type": "npm",
            "script": "start",
            "label": "run",
            "dependsOn": ["build"],
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "clean",
            "command": "sh",
            "args": [
                "-c",
                "rm -f src/**/*.js src/**/*.map"
            ],
            "presentation": {
                "reveal": "silent"
            }
        }
    ]
}